{
  "name": "openpalette",
  "version": "0.9.9",
  "description": "A local-first, open-source design color platform built with Next.js, TypeScript, and Tailwind CSS.",
  "private": true,
  "license": "MIT",
  "author": "Sparsh Sam",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sparshsam/openpalette.git"
  },
  "bugs": {
    "url": "https://github.com/sparshsam/openpalette/issues"
  },
  "homepage": "https://github.com/sparshsam/openpalette#readme",
  "keywords": [
    "color-palette",
    "palette-generator",
    "nextjs",
    "typescript",
    "tailwindcss",
    "local-first",
    "open-source"
  ],
  "engines": {
    "node": ">=22.0.0 <25.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@11.11.0",
  "overrides": {
    "postcss": "^8.5.10"
  },
  "scripts": {
    "dev": "next dev -p 1997",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "analyze": "ANALYZE=true next build"
  },
  "dependencies": {
    "next": "^16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.9",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "playwright": "^1.60.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
